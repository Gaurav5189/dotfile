{
    "layer": "top",
    "margin-top": 0,
    "margin-bottom": 0,
    "margin-left": 0,
    "margin-right": 0,
    "spacing": 0,
    "include": [
        "~/.config/ml4w/settings/waybar-quicklinks.json",
        "~/.config/waybar/modules.json"
    ],
    "modules-left": [
        "custom/appmenu",
        "hyprland/workspaces",
        "group/quicklinks",
        "wlr/taskbar#custom",
        "custom/empty"
    ],
    "modules-center": [],
    "modules-right": [
        "pulseaudio",
        "network",
        "battery",
        "disk#custom",
        "cpu#custom",
        "memory#custom",
        "group/tools",
        "tray",
        "custom/notification",
        "custom/exit",
        "custom/ml4w-welcome",
        "clock"
    ],
    "wlr/taskbar#custom": {
        "format": "{icon}",
        "icon-size": 22,
        "icon-theme": "Numix-Circle",
        "tooltip-format": "{title}",
        "on-click": "activate",
        "on-click-middle": "close",
        "all-outputs": true,
        "ignore-list": ["Waybar"]
    },
    "disk#custom": {
        "interval": 30,
        "format": "   {percentage_used}%",
        "path": "/"
    },
    "cpu#custom": {
        "interval": 2,
        "format": "   {usage}%",
        "tooltip": false
    },
    "memory#custom": {
        "interval": 2,
        "format": "<span color='#50fa7b'>   {percentage}%</span>  |  <span color='#ffb86c'>swap   {swapPercentage}%</span>"
    }
}
